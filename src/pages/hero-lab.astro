---
import Layout from '../layouts/Layout.astro'
import Eyebrow from '../components/site/Eyebrow.astro'
import { VARIANTS } from '../components/hero-lab/types'
---
<Layout title="Black-hole physics lab — jeremn.dev">
  <main class="relative z-10 mx-auto max-w-6xl px-6 pb-10 pt-2">
    <Eyebrow class="block text-accent">Hero lab · not shipped</Eyebrow>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight tracking-tight text-ink sm:text-5xl">
      Black-hole physics, six ways
    </h1>
    <p class="mt-4 max-w-[60ch] font-display text-lg text-muted">
      The same galaxy and the same cursor in every tile — only the warp law changes.
    </p>

    <div class="relative mt-8 h-[78vh] min-h-[600px] w-full overflow-hidden rounded-lg border border-line">
      <canvas id="lab" class="absolute inset-0 block h-full w-full"></canvas>
      <div class="pointer-events-none absolute inset-0 grid grid-cols-3 grid-rows-2">
        {VARIANTS.map((v) => (
          <div class="relative border border-line/30 p-3">
            <div class="inline-block max-w-[30ch] rounded-md bg-ground/55 p-2.5 backdrop-blur-sm">
              <div class="flex items-baseline gap-2">
                <span class="font-mono text-xs" style={`color:${v.accent}`}>{String(v.id).padStart(2, '0')}</span>
                <span class="font-grotesk text-sm font-bold text-ink">{v.name}</span>
              </div>
              <code class="mt-1 block font-mono text-[11px] text-accent">{v.law}</code>
              <p class="mt-1.5 font-mono text-[10.5px] leading-snug text-muted">{v.blurb}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  import { initLab } from '../components/hero-lab/lab.client'
  const canvas = document.getElementById('lab') as HTMLCanvasElement | null
  if (canvas) {
    try { initLab(canvas) } catch (err) { console.error('[HeroLab] init failed:', err) }
  }
</script>
