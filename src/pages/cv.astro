---
import Layout from '../layouts/Layout.astro'
import Eyebrow from '../components/site/Eyebrow.astro'
import Tag from '../components/site/Tag.astro'

const lead =
  'Senior fullstack JavaScript engineer building modern frontends — SvelteKit, Next.js, React, TanStack Start — and their Node backends. Shipping for product teams and agencies since 2016.'

const projects = [
  {
    client: 'ViaMichelin',
    role: 'Senior fullstack',
    period: '2024 — present',
    blurb:
      'Progressive rebuild of the public ViaMichelin site (mapping, routing, related services) within a 14-person product team.',
    stack: ['SvelteKit', 'Fastify', 'GraphQL', 'Web perf'],
  },
  {
    client: 'Upply',
    role: 'Front-end',
    period: '2023 — 24',
    blurb: 'B2B SaaS for price & capacity forecasting across transport and logistics.',
    stack: ['Next.js', 'React Query', 'GraphQL', 'TypeScript'],
  },
  {
    client: 'France Télévisions',
    role: 'JS developer',
    period: '2023',
    blurb:
      'Rebuild of the France 3 régions and La 1ère sites, centered on web performance for high-traffic audiences.',
    stack: ['SvelteKit', 'TypeScript', 'Web perf'],
  },
  {
    client: 'Citroën / Groupe PSA',
    role: 'Front-end consultant (via Liamone)',
    period: '2017 — 18',
    blurb: 'Citroën marketing site and vehicle configurator.',
    stack: ['Front-end', 'SASS', 'Web perf'],
  },
]

const stack = [
  { label: 'Frontend', items: ['SvelteKit', 'Svelte', 'Next.js', 'React', 'TanStack Start', 'TypeScript'] },
  { label: 'Backend', items: ['Node', 'Fastify', 'GraphQL', 'REST'] },
  { label: 'Quality', items: ['Vitest', 'Jest', 'Playwright', 'Cypress', 'Storybook'] },
  { label: 'CI/CD & Ops', items: ['GitLab CI', 'GitHub Actions', 'Docker', 'Vite'] },
  { label: 'Also', items: ['Web Performance', 'i18n', 'SEO', 'Agile'] },
]

const links = [
  { label: 'Malt', href: 'https://www.malt.fr/profile/jeremienehlil' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/j%C3%A9r%C3%A9mie-n%C3%A9hlil-36932a41/' },
  { label: 'GitHub', href: 'https://github.com/jeremN' },
]
---
<Layout
  title="CV — jeremn.dev"
  description="Selected work, stack, and background of Jérémie Néhlil — senior fullstack JavaScript engineer."
>
  <main class="relative z-10 mx-auto max-w-3xl px-6 pb-24 pt-2">
    <Eyebrow class="block text-accent">Curriculum Vitae</Eyebrow>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink sm:text-7xl">CV</h1>
    <p class="mt-8 max-w-[60ch] font-display text-lg text-muted">{lead}</p>
    <p class="mt-4 font-mono text-xs text-muted">
      Near Paris (Sorel-Moussel), France · French (native), English (professional)
    </p>

    <section class="mt-16">
      <Eyebrow class="block">Selected work</Eyebrow>
      <ul class="mt-6 space-y-8">
        {projects.map((p) => (
          <li class="border-t border-line pt-6">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h2 class="font-display text-2xl font-semibold text-ink">{p.client}</h2>
              <span class="font-mono text-xs text-muted">{p.period}</span>
            </div>
            <p class="mt-1 font-mono text-xs uppercase tracking-wider text-accent">{p.role}</p>
            <p class="mt-3 text-sm text-muted">{p.blurb}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.stack.map((s) => <Tag>{s}</Tag>)}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Stack</Eyebrow>
      <dl class="mt-6 space-y-5">
        {stack.map((group) => (
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-6">
            <dt class="w-32 shrink-0 pt-1 font-mono text-xs uppercase tracking-wider text-muted">{group.label}</dt>
            <dd class="flex flex-wrap gap-2">
              {group.items.map((s) => <Tag>{s}</Tag>)}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Education &amp; certifications</Eyebrow>
      <ul class="mt-6 space-y-3 text-sm text-muted">
        <li><span class="text-ink">WebForce3</span> — Web developer / integrator · 2016</li>
        <li><span class="text-ink">SAE Institute Paris</span> — Digital Film &amp; Multimedia · 2010</li>
        <li class="pt-2 font-mono text-xs">Certifications — TestingJavaScript · EpicReact</li>
      </ul>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Full profile</Eyebrow>
      <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 font-mono text-sm">
        {links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="text-accent no-underline transition-colors hover:text-ink">{l.label} →</a>
        ))}
      </div>
    </section>
  </main>
</Layout>
