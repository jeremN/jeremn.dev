---
import Layout from '../layouts/Layout.astro'
import Eyebrow from '../components/site/Eyebrow.astro'
import Tag from '../components/site/Tag.astro'
import { profile, experiences, stack, education, certs, links } from '../lib/cv'
---
<Layout
  title="CV · jeremn.dev"
  description="Selected work, stack, and background of Jérémie Néhlil, senior fullstack JavaScript engineer."
>
  <main class="relative z-10 mx-auto max-w-3xl px-6 pb-24 pt-2">
    <Eyebrow class="block text-accent">Curriculum Vitae</Eyebrow>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink sm:text-7xl">CV</h1>
    <p class="mt-8 max-w-[60ch] font-display text-lg text-muted">{profile.lead}</p>
    <p class="mt-4 font-mono text-xs text-muted">{profile.location} · {profile.languages}</p>
    <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-sm">
      <a href={`mailto:${profile.email}`} class="text-accent no-underline transition-colors hover:text-ink">{profile.email}</a>
      <a href="/cv.pdf" class="text-accent no-underline transition-colors hover:text-ink">Download PDF ↓</a>
    </div>

    <section class="mt-16">
      <Eyebrow class="block">Selected work</Eyebrow>
      <ul class="mt-6">
        {experiences.map((p) => (
          <li data-experience class="grid grid-cols-[7rem_1fr] gap-x-5 border-t border-line py-6 sm:grid-cols-[10rem_1fr] sm:gap-x-10">
            <div>
              <span class="block font-mono text-xs text-muted">{p.period}</span>
              <span class="mt-1.5 block font-mono text-[10px] uppercase tracking-wider text-accent">{p.role}</span>
              <span class="mt-1 block font-mono text-[10px] uppercase tracking-wider text-muted">
                {p.kind === 'agency' ? 'Agency / ESN' : 'Freelance'}
              </span>
            </div>
            <div>
              <h2 class="font-display text-2xl font-semibold text-ink sm:text-3xl">{p.company}</h2>
              <p class="mt-2 text-sm text-muted">{p.blurb}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {p.stack.map((s) => <Tag>{s}</Tag>)}
              </div>
              {p.missions && (
                <ul class="mt-6 space-y-5 border-l border-line pl-5">
                  {p.missions.map((m) => (
                    <li data-mission>
                      <div class="flex flex-wrap items-baseline gap-x-3">
                        <h3 class="font-display text-lg font-semibold text-ink">{m.client}</h3>
                        <span class="font-mono text-[10px] uppercase tracking-wider text-muted">{m.period}</span>
                      </div>
                      <p class="mt-1.5 text-sm text-muted">{m.blurb}</p>
                      {m.note && <p class="mt-1.5 text-xs italic text-muted">{m.note}</p>}
                      <div class="mt-3 flex flex-wrap gap-2">
                        {m.stack.map((s) => <Tag>{s}</Tag>)}
                      </div>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Stack</Eyebrow>
      <dl class="mt-6 space-y-5">
        {stack.map((group) => (
          <div class="flex flex-col gap-2 sm:flex-row sm:gap-6">
            <dt class="w-32 shrink-0 pt-1 font-mono text-xs uppercase tracking-wider text-muted">{group.label}</dt>
            <dd class="flex flex-wrap gap-2">
              {group.items.map((s) => <Tag>{s}</Tag>)}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Education &amp; certifications</Eyebrow>
      <dl class="mt-6">
        {education.map((e) => (
          <div class="grid grid-cols-[7rem_1fr] gap-x-5 border-t border-line py-4 sm:grid-cols-[10rem_1fr] sm:gap-x-10">
            <dt class="font-mono text-xs text-muted">{e.year}</dt>
            <dd class="text-sm text-muted"><span class="text-ink">{e.title}</span> · {e.detail}</dd>
          </div>
        ))}
        <div class="grid grid-cols-[7rem_1fr] gap-x-5 border-t border-line py-4 sm:grid-cols-[10rem_1fr] sm:gap-x-10">
          <dt class="font-mono text-xs uppercase tracking-wider text-muted">Certs</dt>
          <dd class="font-mono text-xs text-muted">{certs.join(' · ')}</dd>
        </div>
      </dl>
    </section>

    <section class="mt-16">
      <Eyebrow class="block">Full profile</Eyebrow>
      <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 font-mono text-sm">
        {links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="text-accent no-underline transition-colors hover:text-ink">{l.label} →</a>
        ))}
      </div>
    </section>
  </main>
</Layout>
