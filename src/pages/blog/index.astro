---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Eyebrow from '../../components/site/Eyebrow.astro'
import { readingTime } from '../../lib/reading-time'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
)

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---
<Layout
  title="Writing — jeremn.dev"
  description="Essays and notes by Jérémie Néhlil on web development, performance, and the tooling around it."
>
  <main class="relative z-10 mx-auto max-w-3xl px-6 pb-24 pt-2">
    <Eyebrow class="block text-accent">Writing</Eyebrow>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink sm:text-7xl">Writing</h1>

    {posts.length === 0 ? (
      <p class="mt-10 text-muted">Posts are coming soon.</p>
    ) : (
      <ul class="mt-12">
        {posts.map((p) => (
          <li>
            <a href={`/blog/${p.id}`} class="group block border-t border-line py-8 no-underline">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h2 class="font-display text-2xl font-semibold leading-tight text-ink transition-colors group-hover:text-accent sm:text-3xl">{p.data.title}</h2>
                <span class="shrink-0 font-mono text-xs text-muted">{fmt(p.data.publishedAt)}</span>
              </div>
              <p class="mt-2 font-mono text-xs uppercase tracking-wider text-muted">
                {[...p.data.tags, readingTime(p.body)].join(' · ')}
              </p>
              <p class="mt-3 text-muted">{p.data.summary}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
