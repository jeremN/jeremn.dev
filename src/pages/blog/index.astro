---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Eyebrow from '../../components/site/Eyebrow.astro'
import PostRow from '../../components/site/PostRow.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
)
---
<Layout
  title="Writing · jeremn.dev"
  description="Essays and notes by Jérémie Néhlil on web development, performance, and the tooling around it."
>
  <main class="relative z-10 mx-auto max-w-3xl px-6 pb-24 pt-2">
    <Eyebrow class="block text-accent">Writing</Eyebrow>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink sm:text-7xl">Writing</h1>

    {posts.length === 0 ? (
      <div class="mt-12 border-t border-line pt-14">
        <p class="max-w-[26ch] font-display text-3xl leading-tight text-ink sm:text-4xl">
          Nothing published yet.
        </p>
        <p class="mt-5 font-mono text-xs text-muted">The first post is in progress.</p>
      </div>
    ) : (
      <ul class="mt-12">
        {posts.map((p) => (
          <li>
            <PostRow slug={p.id} title={p.data.title} summary={p.data.summary} tags={p.data.tags} publishedAt={p.data.publishedAt} body={p.body} />
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
