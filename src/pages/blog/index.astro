---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Eyebrow from '../../components/site/Eyebrow.astro'
import PostCard from '../../components/site/PostCard.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
---
<Layout title="Writing — jeremn.dev">
  <main class="relative z-10 mx-auto max-w-5xl px-6 pb-10 pt-2">
    <Eyebrow class="block text-accent">Writing</Eyebrow>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight text-ink sm:text-7xl">Writing</h1>
    {posts.length === 0 ? (
      <p class="mt-8 text-muted">Posts are coming soon.</p>
    ) : (
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => (
          <PostCard slug={p.id} title={p.data.title} summary={p.data.summary} tags={p.data.tags} publishedAt={p.data.publishedAt} />
        ))}
      </div>
    )}
  </main>
</Layout>
