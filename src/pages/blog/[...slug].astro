---
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Eyebrow from '../../components/site/Eyebrow.astro'
import { readingTime } from '../../lib/reading-time'
import { withBase } from '../../lib/base'

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
  )
  // Newest-first: index i has its newer neighbour at i-1, older at i+1.
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, newer: posts[i - 1] ?? null, older: posts[i + 1] ?? null },
  }))
}

const { post, newer, older } = Astro.props
const { Content, headings } = await render(post)
const date = post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
const meta = [date, readingTime(post.body), ...post.data.tags]
// "On this page" rail — only worth showing once a post has real structure.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3)
const showToc = toc.length >= 2
---
<Layout title={`${post.data.title} — jeremn.dev`} description={post.data.summary}>
  <main
    class:list={[
      'relative z-10 mx-auto px-6 pb-24 pt-2',
      showToc
        ? 'max-w-[68ch] lg:max-w-none lg:grid lg:grid-cols-[13rem_minmax(0,68ch)] lg:justify-center lg:gap-x-12'
        : 'max-w-[68ch]',
    ]}
  >
    {showToc && (
      <aside class="hidden lg:block">
        <nav class="sticky top-24" aria-label="On this page">
          <Eyebrow class="mb-3 block">On this page</Eyebrow>
          <ul class="border-l border-line">
            {toc.map((h) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  data-toc={h.slug}
                  class:list={[
                    'toc-link -ml-px block border-l border-transparent py-1 font-mono text-xs leading-snug text-muted transition-colors hover:text-ink',
                    h.depth === 3 ? 'pl-7' : 'pl-4',
                  ]}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <div>
      <a href={withBase('/blog')} class="no-underline"><Eyebrow class="text-accent">← Writing</Eyebrow></a>
    <h1 class="mt-4 font-display text-4xl font-semibold leading-tight tracking-tight text-ink sm:text-5xl">{post.data.title}</h1>
    <div class="mt-6 border-y border-line py-3">
      <p class="font-mono text-[11px] uppercase tracking-wider text-muted">{meta.join(' · ')}</p>
    </div>

    {post.data.summary && (
      <p class="mt-6 font-display text-xl leading-snug text-ink/90 sm:text-2xl">{post.data.summary}</p>
    )}

    <article class="prose mt-10 max-w-none prose-pre:rounded-lg prose-pre:border prose-pre:border-line">
      <Content />
    </article>

    {(newer || older) && (
      <nav class="mt-16 flex justify-between gap-6 border-t border-line pt-8">
        {newer ? (
          <a href={withBase(`/blog/${newer.id}`)} class="group max-w-[45%] no-underline">
            <span class="block font-mono text-[10px] uppercase tracking-wider text-muted">← Newer</span>
            <span class="mt-1 block text-sm text-ink transition-colors group-hover:text-accent">{newer.data.title}</span>
          </a>
        ) : <span></span>}
        {older ? (
          <a href={withBase(`/blog/${older.id}`)} class="group max-w-[45%] text-right no-underline">
            <span class="block font-mono text-[10px] uppercase tracking-wider text-muted">Older →</span>
            <span class="mt-1 block text-sm text-ink transition-colors group-hover:text-accent">{older.data.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}
    </div>
  </main>
</Layout>

<script>
  // Progressive enhancement for the article reading view: a header bar
  // (language label + copy button) on each code block, and hover-revealed
  // permalinks on headings. Heading ids already exist server-side, so deep
  // links work without this; the visible # is just an affordance.
  const article = document.querySelector('article.prose')
  if (article) {
    article.querySelectorAll('pre').forEach((pre) => {
      const figure = document.createElement('figure')
      figure.className = 'code-block'
      const head = document.createElement('div')
      head.className = 'code-block__head'

      const label = document.createElement('span')
      label.className = 'code-block__lang'
      label.textContent = (pre.dataset.language || '').toUpperCase()

      const copy = document.createElement('button')
      copy.type = 'button'
      copy.className = 'code-block__copy'
      copy.textContent = 'Copy'
      copy.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pre.innerText)
          copy.textContent = 'Copied'
          copy.classList.add('is-copied')
        } catch {
          copy.textContent = 'Failed'
        }
        setTimeout(() => {
          copy.textContent = 'Copy'
          copy.classList.remove('is-copied')
        }, 1600)
      })

      head.append(label, copy)
      pre.replaceWith(figure)
      figure.append(head, pre)
    })

    article.querySelectorAll('h2[id], h3[id]').forEach((heading) => {
      const anchor = document.createElement('a')
      anchor.className = 'heading-anchor'
      anchor.href = '#' + heading.id
      anchor.setAttribute('aria-label', 'Link to this section')
      anchor.textContent = '#'
      heading.append(anchor)
    })

    // Table-of-contents scroll-spy: mark the section currently in view.
    const tocLinks = new Map(
      [...document.querySelectorAll<HTMLElement>('[data-toc]')].map((a) => [a.dataset.toc, a]),
    )
    if (tocLinks.size) {
      const headings = [...article.querySelectorAll('h2[id], h3[id]')]
      const visible = new Set<Element>()
      let activeId: string | null = null
      const setActive = (id: string) => {
        if (id === activeId) return
        if (activeId) tocLinks.get(activeId)?.classList.remove('is-active')
        activeId = id
        tocLinks.get(id)?.classList.add('is-active')
      }
      const spy = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) visible.add(e.target)
            else visible.delete(e.target)
          }
          const top = headings.find((h) => visible.has(h))
          if (top) setActive(top.id)
        },
        { rootMargin: '0px 0px -75% 0px' },
      )
      headings.forEach((h) => spy.observe(h))
    }
  }
</script>
