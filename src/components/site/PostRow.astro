---
import { readingTime } from '../../lib/reading-time'
import { withBase } from '../../lib/base'

interface Props {
  slug: string
  title: string
  summary?: string
  tags?: string[]
  publishedAt: Date
  body?: string
}
const { slug, title, summary = '', tags = [], publishedAt, body } = Astro.props
const date = publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
const meta = [...tags, readingTime(body)].join(' · ')
---
<a href={withBase(`/blog/${slug}`)} class="group grid grid-cols-[7rem_1fr] gap-x-5 border-t border-line py-7 no-underline sm:grid-cols-[10rem_1fr] sm:gap-x-10">
  <div class="pt-1.5">
    <span class="block font-mono text-xs text-muted">{date}</span>
    <span class="mt-1.5 block font-mono text-[10px] uppercase tracking-wider text-muted">{meta}</span>
  </div>
  <div>
    <h2 class="font-display text-2xl font-semibold leading-tight text-ink transition-colors group-hover:text-accent sm:text-3xl">{title}</h2>
    {summary && <p class="mt-2 text-muted">{summary}</p>}
  </div>
</a>
