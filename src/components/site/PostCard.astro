---
interface Props {
  slug: string
  title: string
  summary: string
  tags: string[]
  publishedAt: Date
}
const { slug, title, summary, tags, publishedAt } = Astro.props
const date = publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---
<a href={`/blog/${slug}`} class="group block rounded-lg border border-line bg-surface/40 p-6 no-underline transition-colors hover:border-accent/60">
  <div class="flex flex-wrap gap-2">
    {tags.map((t) => (
      <span class="rounded-full border border-line px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-muted">{t}</span>
    ))}
  </div>
  <h3 class="mt-4 font-display text-2xl font-semibold leading-tight text-ink transition-colors group-hover:text-accent">{title}</h3>
  <p class="mt-2 text-sm text-muted">{summary}</p>
  <p class="mt-4 font-mono text-xs text-muted">{date}</p>
</a>
