---
import '../styles.css'
interface Props { title?: string; description?: string; noindex?: boolean; hideFooterCta?: boolean }
const {
  title = 'Jérémie Néhlil',
  description = 'Jérémie Néhlil — freelance software engineer. CV, writing, and a WebGL galaxy.',
  noindex = false,
  hideFooterCta = false,
} = Astro.props
const nav = [
  { href: '/blog', label: 'Writing' },
  { href: '/cv', label: 'CV' },
  { href: '/freelance', label: 'Freelance' },
]
const year = new Date().getFullYear()

const pathname = Astro.url.pathname
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/')
const canonical = Astro.site ? new URL(pathname, Astro.site).href : pathname
const ogImage = Astro.site ? new URL('/og-cover.jpg', Astro.site).href : '/og-cover.jpg'
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Apply the saved theme before paint to avoid a flash. Default: dark.
      try {
        const t = localStorage.getItem('theme')
        document.documentElement.dataset.theme = t === 'light' || t === 'dark' ? t : 'dark'
      } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0a12" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/logo192.png" />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="jeremn.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="antialiased [overflow-wrap:anywhere]">
    <header class="relative z-10 bg-ground">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-5 sm:px-6">
        <a href="/" class="font-grotesk text-lg font-extrabold tracking-tight text-ink no-underline">
          jeremn<span class="text-accent">.</span>dev
        </a>
        <div class="flex items-center gap-4 sm:gap-7">
          <nav class="flex gap-4 sm:gap-7">
            {nav.map((n) => (
              <a href={n.href} class="group no-underline" aria-current={isActive(n.href) ? 'page' : undefined}>
                <span class:list={['eyebrow transition-colors group-hover:text-accent', isActive(n.href) && 'text-accent']}>{n.label}</span>
              </a>
            ))}
          </nav>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Switch between light and dark theme"
            class="-my-1 flex items-center text-muted transition-colors hover:text-accent"
          >
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.4" />
              <path d="M8 1a7 7 0 0 1 0 14z" fill="currentColor" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <slot />

    <footer class="relative z-10 bg-ground">
      <div class="mx-auto max-w-5xl px-6 pb-16 pt-16">
        {!hideFooterCta && (
          <Fragment>
            <span class="eyebrow">Get in touch</span>
            <a href="/freelance" class="block no-underline">
              <h2 class="mt-3 font-display text-5xl font-semibold leading-none tracking-tight text-ink transition-colors hover:text-accent sm:text-7xl">
                Work with me
              </h2>
            </a>
          </Fragment>
        )}
        <p class="mt-8 font-mono text-xs text-muted">© {year} Jérémie Néhlil — jeremn.dev</p>
      </div>
    </footer>

    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light'
        document.documentElement.dataset.theme = next
        try {
          localStorage.setItem('theme', next)
        } catch (e) {}
      })
    </script>
  </body>
</html>
