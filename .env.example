# Local dev: drizzle-kit + the seed script run in Node and accept a file URL.
TURSO_DATABASE_URL=file:./local.db
# The app's SSR runs in the Workers runtime (workerd) which has no filesystem,
# so to serve DB-backed routes locally run `turso dev` (HTTP libSQL) and point
# the app at it instead:
# TURSO_DATABASE_URL=http://127.0.0.1:8080
#
# Production (Turso cloud):
# TURSO_DATABASE_URL=libsql://<your-db>.turso.io
# TURSO_AUTH_TOKEN=<your-token>
